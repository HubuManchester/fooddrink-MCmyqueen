<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#F0F7F0, Dark=#1A2A1A}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F4FAF4, Dark=#1E2E1E}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#2E7D32, Dark=#1B5E20}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#4CAF50, Dark=#2E7D32}" Offset="0.72" />
                        <GradientStop Color="{AppThemeBinding Light=#81C784, Dark=#1B5E20}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <Label x:Name="NameLabel"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label x:Name="CategoryLabel"
                           Grid.Row="1"
                           FontSize="15"
                           TextColor="#FFF5E8" />
                    <Label x:Name="CaloriesLabel"
                           Grid.Row="2"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#FFF0C9" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Nutrition overview" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}" />
                    <Label x:Name="MacroLabel" FontSize="16" TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}" />
                    <Label x:Name="DescriptionLabel" FontSize="15" TextColor="{AppThemeBinding Light=#4A5A4A, Dark=#C8D9C8}" />
                    <Label x:Name="AllergyLabel" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Read summary"
                        BackgroundColor="#2E7D32"
                        TextColor="#FFFFFF"
                        Clicked="OnSpeakClicked"
                        SemanticProperties.Hint="Read the nutrition summary aloud" />
                <Button Grid.Column="1"
                        Text="Stop reading"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}"
                        BorderColor="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop the current speech" />
            </Grid>

            <Button Text="Vibration reminder"
                    BackgroundColor="#2E7D32"
                    TextColor="#FFFFFF"
                    Clicked="OnVibrateClicked"
                    SemanticProperties.Hint="Use mobile vibration as a meal reminder" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>