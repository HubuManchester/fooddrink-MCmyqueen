<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.HardwarePage"
             Title="Hardware Demo">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#F0F7F0, Dark=#1A2A1A}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F4FAF4, Dark=#1E2E1E}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Mobile hardware"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1B3B1B, Dark=#EDF2ED}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Demonstrate camera, location, speech, vibration, and haptic feedback."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5A6E5A, Dark=#C8D9C8}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Food photo" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}" />
                            <Label Text="Capture the colour and condition of the meal." FontSize="13" TextColor="{AppThemeBinding Light=#5A6E5A, Dark=#C8D9C8}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Photo"
                                BackgroundColor="#2E7D32"
                                TextColor="#FFFFFF"
                                Clicked="OnTakePhotoClicked"
                                SemanticProperties.Hint="Open the camera to capture a food image" />
                    </Grid>
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#2A3A2A}"
                            HeightRequest="220">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image x:Name="FoodPhoto"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Captured food photo preview" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Meal location" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                            <Label Text="Show country, city, region, and coordinates." FontSize="13" TextColor="{AppThemeBinding Light=#5A6E5A, Dark=#C8D9C8}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Locate"
                                BackgroundColor="#2E7D32"
                                TextColor="#FFFFFF"
                                Clicked="OnGetLocationClicked"
                                SemanticProperties.Hint="Use location to record the meal place" />
                    </Grid>
                    <Label x:Name="LocationLabel"
                           Grid.Row="1"
                           Text="Location has not been captured yet."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#4A5A4A, Dark=#C8D9C8}" />
                    <Label x:Name="CoordinateLabel"
                           Grid.Row="2"
                           Text="Coordinates will appear here."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#5A6E5A, Dark=#A6B8B0}" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Read help"
                        BackgroundColor="#81C784"
                        TextColor="#1B3B1B"
                        Clicked="OnReadHelpClicked"
                        SemanticProperties.Hint="Read the help text aloud" />
                <Button Grid.Column="1"
                        Text="Stop speech"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}"
                        BorderColor="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop current speech" />
            </Grid>

            <Button Text="Haptic feedback"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}"
                    BorderColor="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}"
                    Clicked="OnFeedbackClicked"
                    SemanticProperties.Hint="Trigger vibration and haptic feedback" />

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#2A3A2A}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="HardwareStatusLabel"
                           Text="Ready."
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                    <Label x:Name="FeedbackCountLabel"
                           Text="Haptic feedback tests: 0"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#4A5A4A, Dark=#C8D9C8}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>