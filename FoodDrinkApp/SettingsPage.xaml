<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.SettingsPage"
             Title="Settings">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#F0F7F0, Dark=#1A2A1A}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F4FAF4, Dark=#1E2E1E}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Accessibility settings"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1B3B1B, Dark=#EDF2ED}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Large text takes effect immediately and remains active when switching pages."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5A6E5A, Dark=#C8D9C8}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#2A3A2A}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Label Text="Theme mode"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}" />
                        <Picker x:Name="ThemePicker"
                                Grid.Row="1"
                                Title="Choose app theme"
                                SelectedIndexChanged="OnThemeChanged"
                                SemanticProperties.Hint="Switch between system, light, and dark theme">
                            <Picker.Items>
                                <x:String>Use system theme</x:String>
                                <x:String>Light theme</x:String>
                                <x:String>Dark theme</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A2E}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Large text mode"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                            <Label Text="Increase text size for accessibility demonstration."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#5A6E5A, Dark=#C8D9C8}" />
                        </VerticalStackLayout>
                        <Switch x:Name="LargeTextSwitch"
                                Grid.Column="1"
                                Toggled="OnLargeTextToggled"
                                SemanticProperties.Hint="Increase text size across the current session" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#2A3A2A}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="LargeTextPreviewTitle"
                           Text="Large text preview"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
                    <Label x:Name="LargeTextPreviewBody"
                           Text="When enabled, this text and the rest of the page become visibly larger."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#4A5A4A, Dark=#C8D9C8}" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="SettingsStatusLabel"
                   Text="Settings ready."
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>