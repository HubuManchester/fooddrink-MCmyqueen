<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodDrinkApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FoodDrinkApp"
    Title="NutriBite"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light=#F4FAF4, Dark=#1A2A1A}"
    Shell.ForegroundColor="{AppThemeBinding Light=#1B3B1B, Dark=#EDF2ED}"
    Shell.TitleColor="{AppThemeBinding Light=#1B3B1B, Dark=#EDF2ED}"
    Shell.UnselectedColor="{AppThemeBinding Light=#8AAA8A, Dark=#5A7A5A}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#F4FAF4, Dark=#1A2A1A}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#8AAA8A, Dark=#5A7A5A}">

    <TabBar>
        <ShellContent
            Title="Foods"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Hardware"
            ContentTemplate="{DataTemplate local:HardwarePage}"
            Route="HardwarePage" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>
</Shell>